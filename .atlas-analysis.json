  "publicApiSurface": [
    "atemporal() - Factory function for creating instances",
    "atemporal.from() - Create from various inputs",
    "atemporal.unix() - Create from Unix timestamp",
    "atemporal.duration() - Create duration objects",
    "atemporal.isValid() - Validate date inputs",
    "atemporal.min() / max() - Compare multiple dates",
    "atemporal.extend() - Load plugins",
    "atemporal.lazyLoad() - Dynamically load plugins",
    ".add() / .subtract() - Date manipulation",
    ".startOf() / .endOf() - Truncate to unit",
    ".format() - Format date strings",
    ".isBefore() / .isAfter() - Date comparison",
    ".diff() - Calculate differences",
    ".timeZone() - Change time zones",
    ".locale() - Set locale for formatting",
    "Plugin: relativeTime - .fromNow() / .toNow()",
    "Plugin: customParseFormat - Parse custom formats",
    "Plugin: advancedFormat - Extended format tokens",
    "Plugin: durationHumanizer - Humanize durations",
    "Plugin: weekDay - Weekday utilities",
    "Plugin: businessDays - Business day calculations",
    "Plugin: timeSlots - Schedule slot management",
    "Plugin: dateRangeOverlap - Range intersection detection"
